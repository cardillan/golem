    @micro-processor     at +(1,  1) processor links  +(0, -1) as message1 +(1, -1) as display1 end mindcode = "#set target = 8m; const p = 7; " + file "test.mnd" end
    @message             at +(0, -1) text ""
    @tile-logic-display  at +(1,  0)
