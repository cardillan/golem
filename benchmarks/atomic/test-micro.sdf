schematic
    name = "Wait Test - Micro Processor"

    @micro-processor     at ( 0,  1) processor links  +(0, -1) as message1 +(1, -1) as display1 end mindcode = "#set target = 8m; const p = 1; " + file "test.mnd" end
    @message             at ( 0,  0) text ""
    @tile-logic-display  at ( 1,  0)

    @micro-processor     at +(1,  1) processor links  +(0, -1) as message1 +(1, -1) as display1 end mindcode = "#set target = 8m; const p = 2; " + file "test.mnd" end
